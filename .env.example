# Required for Gemini embeddings and grounded answer generation
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Local Docker example: http://127.0.0.1:6333
# Qdrant Cloud example: https://<cluster-id>.<region>.cloud.qdrant.io:6333
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=ask_my_doc_rag
RAG_TOP_K=5
MAX_FILE_SIZE_MB=10
